#!/bin/sh
command -v bluetoothctl >/dev/null 2>&1 || exit 0

show=$(bluetoothctl show 2>/dev/null) || exit 0
printf '%s\n' "$show" | grep -q '^Controller ' || exit 0

if [ "${DWM_STATUS_CLICK:-0}" != 1 ]; then
	BLOCK_BUTTON=
fi

powered=$(printf '%s\n' "$show" | awk -F': ' '/Powered:/ { print $2; exit }')
connected=$(bluetoothctl devices Connected 2>/dev/null | sed -n 's/^Device [0-9A-Fa-f:][0-9A-Fa-f:]* //p; 1q')

case "${BLOCK_BUTTON:-}" in
1) setsid -f kitty --class float -T Bluetooth -e bt-console >/dev/null 2>&1 ;;
2) setsid -f bluetooth-menu >/dev/null 2>&1 ;;
3)
	[ "$powered" = yes ] && bluetoothctl power off >/dev/null 2>&1 || bluetoothctl power on >/dev/null 2>&1
	notify-send -a bluetooth -t 1200 "Bluetooth" "power toggled"
	pkill -RTMIN+5 dwmblocks 2>/dev/null || :
	;;
esac

if [ "$powered" != yes ]; then
	printf 'BT off\n'
elif [ -n "$connected" ]; then
	printf 'BT %.18s\n' "$connected"
else
	printf 'BT on\n'
fi
