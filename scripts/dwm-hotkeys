#!/bin/sh
set -eu

lockfile=${XDG_RUNTIME_DIR:-/tmp}/dwm-hotkeys.lock
if ! mkdir "$lockfile" 2>/dev/null; then
	exit 0
fi
trap 'rm -rf "$lockfile"' EXIT INT TERM

cache=${XDG_CACHE_HOME:-"$HOME/.cache"}/dwm-hotkeys
bin=$cache/dwm-hotkeys-xi
src=$cache/dwm-hotkeys-xi.c
mkdir -p "$cache"

if [ ! -x "$bin" ]; then
	cat > "$src" <<'C'
#include <signal.h>
#include <stdio.h>
#include <stdlib.h>
#include <time.h>
#include <unistd.h>
#include <sys/wait.h>
#include <X11/Xlib.h>
#include <X11/keysym.h>
#include <X11/extensions/XInput2.h>

static int key_down(char keys[32], KeyCode code) {
	return keys[code >> 3] & (1 << (code & 7));
}

static void reap(int sig) {
	(void)sig;
	while (waitpid(-1, NULL, WNOHANG) > 0)
		;
}

static void lock_screen(void) {
	if (fork() == 0) {
		execlp("slock", "slock", (char *)NULL);
		_exit(127);
	}
}

int main(void) {
	Display *dpy;
	Window root;
	int opcode, event, error;
	unsigned char mask[(XI_LASTEVENT + 7) / 8] = {0};
	XIEventMask evmask;
	KeyCode xkey, super_l, super_r;
	time_t last = 0;

	signal(SIGCHLD, reap);
	dpy = XOpenDisplay(NULL);
	if (!dpy)
		return 1;
	if (!XQueryExtension(dpy, "XInputExtension", &opcode, &event, &error))
		return 1;

	root = DefaultRootWindow(dpy);
	xkey = XKeysymToKeycode(dpy, XK_x);
	super_l = XKeysymToKeycode(dpy, XK_Super_L);
	super_r = XKeysymToKeycode(dpy, XK_Super_R);
	if (!xkey || (!super_l && !super_r))
		return 1;

	XISetMask(mask, XI_RawKeyPress);
	evmask.deviceid = XIAllMasterDevices;
	evmask.mask_len = sizeof(mask);
	evmask.mask = mask;
	XISelectEvents(dpy, root, &evmask, 1);
	XFlush(dpy);

	for (;;) {
		XEvent ev;
		XGenericEventCookie *cookie;
		XIRawEvent *raw;
		char keys[32];
		time_t now;

		XNextEvent(dpy, &ev);
		cookie = &ev.xcookie;
		if (cookie->type != GenericEvent || cookie->extension != opcode)
			continue;
		if (!XGetEventData(dpy, cookie))
			continue;
		if (cookie->evtype == XI_RawKeyPress) {
			raw = cookie->data;
			if (raw->detail == xkey) {
				XQueryKeymap(dpy, keys);
				now = time(NULL);
				if ((key_down(keys, super_l) || key_down(keys, super_r)) && now != last) {
					last = now;
					lock_screen();
				}
			}
		}
		XFreeEventData(dpy, cookie);
	}
}
C
	cc "$src" -o "$bin" -lXi -lX11
fi

exec "$bin"
