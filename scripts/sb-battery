#!/bin/sh
bat=$(find /sys/class/power_supply -maxdepth 1 -name 'BAT*' 2>/dev/null | sed -n '1p')
[ -n "$bat" ] || exit 0

cap=$(cat "$bat/capacity" 2>/dev/null)
status=$(cat "$bat/status" 2>/dev/null)
[ -n "$cap" ] || exit 0

if [ "${DWM_STATUS_CLICK:-0}" != 1 ]; then
	BLOCK_BUTTON=
fi

case "${BLOCK_BUTTON:-}" in
1) notify-send "Battery" "$cap% ${status:-unknown}" ;;
esac

printf 'BAT %s%%\n' "$cap"
