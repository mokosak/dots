#!/bin/sh
export PATH="$HOME/.local/bin:/usr/local/bin:$PATH"
export SUDO_ASKPASS="$HOME/.local/bin/dmenupass"
export _JAVA_AWT_WM_NONREPARENTING=1
export XDG_CURRENT_DESKTOP=dwm
export DESKTOP_SESSION=dwm
export XDG_SESSION_TYPE=x11
export GTK_USE_PORTAL=1

[ -f "$HOME/.Xresources" ] && xrdb -merge "$HOME/.Xresources"
command -v wall >/dev/null 2>&1 && wall apply >/dev/null 2>&1 || xsetroot -solid "#1f2430"
command -v xsetroot >/dev/null 2>&1 && xsetroot -cursor_name left_ptr
command -v bluetoothctl >/dev/null 2>&1 && bluetoothctl power off >/dev/null 2>&1 || :
command -v wpctl >/dev/null 2>&1 && wpctl set-mute @DEFAULT_AUDIO_SINK@ 1 >/dev/null 2>&1 || :
command -v wpctl >/dev/null 2>&1 && wpctl set-mute @DEFAULT_AUDIO_SOURCE@ 1 >/dev/null 2>&1 || :

if command -v dbus-update-activation-environment >/dev/null 2>&1; then
	dbus-update-activation-environment --systemd DISPLAY XAUTHORITY DBUS_SESSION_BUS_ADDRESS \
		XDG_CURRENT_DESKTOP DESKTOP_SESSION XDG_SESSION_TYPE >/dev/null 2>&1 || :
fi

command -v mpd >/dev/null 2>&1 && ! pgrep -x mpd >/dev/null 2>&1 && mpd "$HOME/.config/mpd/mpd.conf" >/tmp/mpd.log 2>&1 &
command -v picom >/dev/null 2>&1 && picom --config "$HOME/.config/picom/picom.conf" &
command -v dunst >/dev/null 2>&1 && dunst &
command -v nightlight >/dev/null 2>&1 && ! pgrep -u "$USER" -f "nightlight daemon" >/dev/null 2>&1 && nightlight daemon >/tmp/nightlight.log 2>&1 &
command -v dwmblocks >/dev/null 2>&1 && dwmblocks &
command -v kb-watch >/dev/null 2>&1 && kb-watch >/tmp/kb-watch.log 2>&1 &

exec dwm
